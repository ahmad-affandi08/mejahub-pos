// ============================================================
// MejaHub - Cloud POS & F&B Ecosystem
// Prisma Schema for MySQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  CASHIER
  WAITER
  KITCHEN_STAFF
  BAR_STAFF
}

enum TableStatus {
  AVAILABLE    // Hijau - Kosong
  OCCUPIED     // Merah - Terisi
  WAITING_FOOD // Kuning - Menunggu Makanan
  REQUESTING_BILL // Biru - Minta Bill
  RESERVED
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
  VOID
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderItemStatus {
  PENDING
  COOKING
  READY
  SERVED
  CANCELLED
}

enum KitchenStation {
  KITCHEN
  BAR
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT_CARD
  CREDIT_CARD
  E_WALLET
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum StockMovementType {
  IN
  OUT
  WASTE
  ADJUSTMENT
}

enum CashDrawerType {
  CASH_IN
  CASH_OUT
}

enum ModifierType {
  SINGLE  // Radio button - pilih satu  (Level Pedas)
  MULTIPLE // Checkbox - pilih banyak (Topping)
}

enum UnitType {
  KILOGRAM
  GRAM
  LITER
  MILILITER
  PIECE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VOID_ORDER
  VOID_ITEM
  REFUND
  SHIFT_OPEN
  SHIFT_CLOSE
  LOGIN
  LOGOUT
}

// ============================================================
// MASTER TABLES
// ============================================================

model Branch {
  id          String   @id @default(cuid())
  name        String
  address     String?  @db.Text
  phone       String?
  taxRate     Decimal  @default(10.00) @db.Decimal(5, 2) // PB1 default 10%
  serviceRate Decimal  @default(5.00) @db.Decimal(5, 2)  // Service charge default 5%
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  tables          Table[]
  categories      Category[]
  products        Product[]
  orders          Order[]
  ingredients     Ingredient[]
  shifts          Shift[]
  stockMovements  StockMovement[]
  auditLogs       AuditLog[]

  @@map("branches")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  role           UserRole @default(CASHIER)
  pin            String?  // Quick PIN for POS operations
  isActive       Boolean  @default(true)
  branchId       String?
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch          Branch?              @relation(fields: [branchId], references: [id])
  orders          Order[]
  shifts          Shift[]
  cashDrawerTxns  CashDrawerTransaction[]
  auditLogs       AuditLog[]
  accounts        Account[]
  sessions        Session[]

  @@index([branchId])
  @@index([email])
  @@map("users")
}

// NextAuth.js required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Table {
  id         String      @id @default(cuid())
  number     Int
  name       String?     // e.g., "Meja VIP 1"
  capacity   Int         @default(4)
  status     TableStatus @default(AVAILABLE)
  qrCode     String?     @unique // Dynamic QR Code URL
  positionX  Int         @default(0) // Grid position for visual map
  positionY  Int         @default(0)
  branchId   String
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id])
  orders  Order[]

  @@unique([branchId, number])
  @@index([branchId])
  @@index([status])
  @@map("tables")
}

// ============================================================
// CATALOG TABLES
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  branchId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  products Product[]

  @@index([branchId])
  @@map("categories")
}

model Product {
  id             String         @id @default(cuid())
  name           String
  description    String?        @db.Text
  price          Decimal        @db.Decimal(12, 2)
  image          String?
  sku            String?
  station        KitchenStation @default(KITCHEN) // Routing ke KDS
  isAvailable    Boolean        @default(true)
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  categoryId     String
  branchId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  branch          Branch           @relation(fields: [branchId], references: [id])
  variants        ProductVariant[]
  modifierGroups  ProductModifierGroup[]
  recipes         Recipe[]
  orderItems      OrderItem[]

  @@index([categoryId])
  @@index([branchId])
  @@index([station])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  name       String   // e.g., "Small", "Medium", "Large"
  price      Decimal  @db.Decimal(12, 2) // Override price
  sku        String?
  isActive   Boolean  @default(true)
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ModifierGroup {
  id          String       @id @default(cuid())
  name        String       // e.g., "Level Pedas", "Topping"
  type        ModifierType @default(SINGLE)
  isRequired  Boolean      @default(false)
  minSelect   Int          @default(0)
  maxSelect   Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  modifiers  Modifier[]
  products   ProductModifierGroup[]

  @@map("modifier_groups")
}

// Junction table: Product <-> ModifierGroup
model ProductModifierGroup {
  id              String @id @default(cuid())
  productId       String
  modifierGroupId String

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@map("product_modifier_groups")
}

model Modifier {
  id              String   @id @default(cuid())
  name            String   // e.g., "Pedas Level 3", "Tambah Boba"
  price           Decimal  @default(0) @db.Decimal(12, 2) // Additional price
  isActive        Boolean  @default(true)
  modifierGroupId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modifierGroup      ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
  @@map("modifiers")
}

// ============================================================
// TRANSACTION TABLES
// ============================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // Auto-generated: ORD-YYYYMMDD-XXXX
  type            OrderType   @default(DINE_IN)
  status          OrderStatus @default(OPEN)
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(12, 2)
  taxRate         Decimal     @default(0) @db.Decimal(5, 2) // Snapshot from branch
  serviceAmount   Decimal     @default(0) @db.Decimal(12, 2)
  serviceRate     Decimal     @default(0) @db.Decimal(5, 2) // Snapshot from branch
  discountAmount  Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal     @default(0) @db.Decimal(12, 2)
  notes           String?     @db.Text
  customerName    String?
  customerPhone   String?     // For e-receipt via WA
  tableId         String?
  branchId        String
  userId          String      // Cashier/Waiter who created
  shiftId         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  table      Table?      @relation(fields: [tableId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  shift      Shift?      @relation(fields: [shiftId], references: [id])
  items      OrderItem[]
  payments   Payment[]

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([tableId])
  @@index([userId])
  @@index([shiftId])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(cuid())
  quantity        Int             @default(1)
  unitPrice       Decimal         @db.Decimal(12, 2) // Price snapshot at order time
  subtotal        Decimal         @db.Decimal(12, 2) // quantity * unitPrice + modifiers
  notes           String?
  status          OrderItemStatus @default(PENDING)
  station         KitchenStation  @default(KITCHEN)
  cookingStartAt  DateTime?       // When status -> COOKING
  readyAt         DateTime?       // When status -> READY
  servedAt        DateTime?       // When status -> SERVED
  orderId         String
  productId       String
  variantId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([status])
  @@index([station])
  @@index([createdAt])
  @@map("order_items")
}

model OrderItemModifier {
  id          String  @id @default(cuid())
  name        String  // Snapshot modifier name
  price       Decimal @db.Decimal(12, 2) // Snapshot modifier price
  orderItemId String
  modifierId  String

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier  Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// ============================================================
// INVENTORY TABLES
// ============================================================

model Ingredient {
  id           String   @id @default(cuid())
  name         String
  unit         UnitType @default(GRAM)
  currentStock Decimal  @default(0) @db.Decimal(12, 3)
  minStock     Decimal  @default(0) @db.Decimal(12, 3) // Reorder point
  costPerUnit  Decimal  @default(0) @db.Decimal(12, 2)
  branchId     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  recipes        Recipe[]
  stockMovements StockMovement[]

  @@index([branchId])
  @@map("ingredients")
}

// Bill of Materials - Recipe mapping Product -> Ingredient
model Recipe {
  id           String  @id @default(cuid())
  quantity     Decimal @db.Decimal(12, 3) // Amount of ingredient used per product
  productId    String
  ingredientId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@map("recipes")
}

model StockMovement {
  id           String            @id @default(cuid())
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 3)
  notes        String?           @db.Text
  ingredientId String
  branchId     String
  createdAt    DateTime          @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])

  @@index([ingredientId])
  @@index([branchId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ============================================================
// FINANCIAL TABLES
// ============================================================

model Payment {
  id            String        @id @default(cuid())
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(12, 2)
  receivedAmount Decimal      @default(0) @db.Decimal(12, 2) // Amount tendered
  changeAmount  Decimal       @default(0) @db.Decimal(12, 2)
  reference     String?       // External reference (QRIS ID, etc.)
  orderId       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}

model Shift {
  id                String    @id @default(cuid())
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  openingCash       Decimal   @db.Decimal(12, 2) // Modal awal
  closingCash       Decimal?  @db.Decimal(12, 2) // Kas akhir (input kasir - blind)
  expectedCash      Decimal?  @db.Decimal(12, 2) // Perhitungan sistem
  cashDifference    Decimal?  @db.Decimal(12, 2) // Selisih
  totalSales        Decimal   @default(0) @db.Decimal(12, 2)
  totalOrders       Int       @default(0)
  notes             String?   @db.Text
  userId            String
  branchId          String    // Denormalized for query performance
  createdAt         DateTime  @default(now())

  user              User                   @relation(fields: [userId], references: [id])
  branch            Branch                 @relation(fields: [branchId], references: [id])
  orders            Order[]
  cashTransactions  CashDrawerTransaction[]

  @@index([userId])
  @@index([branchId])
  @@index([openedAt])
  @@map("shifts")
}

model CashDrawerTransaction {
  id        String         @id @default(cuid())
  type      CashDrawerType
  amount    Decimal        @db.Decimal(12, 2)
  reason    String
  shiftId   String
  userId    String
  createdAt DateTime       @default(now())

  shift Shift @relation(fields: [shiftId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([shiftId])
  @@map("cash_drawer_transactions")
}

// ============================================================
// AUDIT & LOGGING
// ============================================================

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entity     String      // Table name affected
  entityId   String?     // ID of the record affected
  oldData    Json?       // Previous state (JSON snapshot)
  newData    Json?       // New state (JSON snapshot)
  ipAddress  String?
  userAgent  String?     @db.Text
  userId     String
  branchId   String?
  createdAt  DateTime    @default(now())

  user   User    @relation(fields: [userId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([userId])
  @@index([branchId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
